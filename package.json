{
  "name": "external-mcp-monorepo",
  "version": "0.0.0",
  "license": "MIT AND Apache-2.0",
  "scripts": {
    "build": "pnpm --filter @recallnet/mcp-types build && turbo build",
    "dev": "turbo dev --concurrency=20",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test -- --verbose",
    "clean": "turbo clean && pnpm --filter @recallnet/mcp-types clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish",
    "docs:build": "turbo docs:build",
    "docs:check": "turbo docs:check",
    "prepare": "pnpm --filter @recallnet/mcp-types build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.12",
    "@jest/globals": "^29.7.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.1",
    "@types/jest": "^29.5.11",
    "dotenv": "^16.5.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "@typescript-eslint/parser": "^8.23.0",
    "@typescript-eslint/utils": "^8.23.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.4.0",
    "turbo": "^2.3.7",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "shared",
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/recallnet/external-mcp.git"
  }
}
