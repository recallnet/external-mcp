{
  "name": "@recallnet/external-mcp",
  "version": "1.0.0",
  "description": "A modular Model Context Protocol (MCP) library providing access to various external data feeds",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./twitter": {
      "import": "./dist/twitter/index.js",
      "types": "./dist/twitter/index.d.ts"
    },
    "./substack": {
      "import": "./dist/substack/index.js",
      "types": "./dist/substack/index.d.ts"
    },
    "./coingecko": {
      "import": "./dist/coingecko/index.js",
      "types": "./dist/coingecko/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "build:twitter": "tsc --project tsconfig.twitter.json",
    "build:substack": "tsc --project tsconfig.substack.json",
    "build:coingecko": "tsc --project tsconfig.coingecko.json",
    "start": "node dist/index.js",
    "start:twitter": "node dist/twitter/server.js",
    "start:substack": "node dist/substack/server.js",
    "start:coingecko": "node dist/coingecko/server.js",
    "start:all": "node dist/index.js",
    "debug:server": "node scripts/debug-server.js",
    "debug:twitter": "node scripts/debug-server.js twitter",
    "debug:substack": "node scripts/debug-server.js substack",
    "debug:coingecko": "node scripts/debug-server.js coingecko",
    "quick:test": "node scripts/quick-test.js",
    "quick:twitter": "node scripts/quick-test.js twitter",
    "quick:substack": "node scripts/quick-test.js substack",
    "quick:coingecko": "node scripts/quick-test.js coingecko",
    "test:stdio-server": "node scripts/test-stdio-server.js",
    "test:stdio-client": "node scripts/test-stdio-client.js",
    "test:combined": "node scripts/test-combined-server.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "mocha --loader=ts-node/esm --experimental-specifier-resolution=node tests/**/*.test.ts",
    "test:substack": "mocha --loader=ts-node/esm --experimental-specifier-resolution=node tests/substack/**/*.test.ts",
    "test:utils": "mocha --loader=ts-node/esm --experimental-specifier-resolution=node tests/utils/**/*.test.ts",
    "test:twitter": "mocha --loader=ts-node/esm --experimental-specifier-resolution=node tests/twitter/**/*.test.ts",
    "test:coingecko": "mocha --loader=ts-node/esm --experimental-specifier-resolution=node tests/coingecko/**/*.test.ts",
    "test:mcp": "mocha --loader=ts-node/esm --experimental-specifier-resolution=node tests/mcp-client-tests.js",
    "test:coverage": "c8 mocha --loader=ts-node/esm --experimental-specifier-resolution=node tests/**/*.test.ts",
    "test:client": "node scripts/test-client.js",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "twitter",
    "substack",
    "coingecko",
    "data-feeds",
    "recall"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@mastra/core": "^0.8.3",
    "@modelcontextprotocol/sdk": "^1.8.0",
    "agent-twitter-client": "^0.0.18",
    "axios": "^1.6.7",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/chai": "^5.2.1",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.12",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.19",
    "c8": "^10.1.3",
    "chai": "^5.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.24.0",
    "jest": "^29.7.0",
    "mocha": "^11.1.0",
    "nyc": "^17.1.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
