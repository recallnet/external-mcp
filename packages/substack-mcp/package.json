{
  "name": "@recallnet/substack-mcp",
  "version": "1.0.0",
  "description": "A Model Context Protocol (MCP) server to retrieve posts, publications, comments, and content",
  "main": "dist/index.js",
  "type": "module",
  "bin": "./dist/index.js",
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "pnpm build",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test": "NODE_ENV=test node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config=../../jest.config.js --testPathPattern=packages/substack-mcp",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf .turbo node_modules dist"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@recallnet/mcp-types": "workspace:*",
    "axios": "^1.6.7",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0",
    "dotenv": "^16.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.19",
    "shx": "^0.4.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/recallnet/external-mcp.git",
    "directory": "packages/substack-mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*"
  ]
}
