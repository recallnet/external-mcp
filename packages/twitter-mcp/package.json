{
  "name": "@recallnet/twitter-mcp",
  "version": "1.0.0",
  "description": "A Model Context Protocol (MCP) server for secure Twitter client integration",
  "main": "dist/index.js",
  "type": "module",
  "bin": "./dist/index.js",
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "test": "NODE_ENV=test node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config=../../jest.config.js --testPathPattern=packages/twitter-mcp",
    "dev": "ts-node src/index.ts",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf .turbo node_modules dist"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "agent-twitter-client": "^0.0.18",
    "chalk": "^4.1.2",
    "dotenv": "^16.3.1",
    "@recallnet/mcp-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.8.2",
    "@types/jest": "^29.5.11",
    "shx": "^0.4.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
