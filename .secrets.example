# Twitter API credentials (required for Twitter MCP tests)
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password
TWITTER_EMAIL=your_twitter_email

# CoinGecko API key (required for CoinGecko MCP tests)
COINGECKO_API_KEY=your_coingecko_api_key

# GitHub token (used for any GitHub API operations)
GITHUB_TOKEN=your_github_token

# Optional parameters that can be configured
# PROXY_URL=http://your-proxy-url
# DEBUG=true 